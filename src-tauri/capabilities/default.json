{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://open.weixin.qq.com/*" },
        { "url": "https://comb-platform.hortorgames.com/*" }
      ]
    }
  ]
}
